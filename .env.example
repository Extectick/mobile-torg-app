# PostgreSQL connection string for Prisma.
# In Docker Compose this value is passed to the web and migrate containers.
# Keep real credentials only in .env, not in this example file.
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# Host port for the nginx proxy.
# The app is available at http://localhost:${WEB_PORT}.
WEB_PORT=3002

# Optional public API base URL for browser-side requests.
# Leave empty when frontend and API are served by the same Next.js app.
# If set, it must usually include /api, for example: https://example.com/api
NEXT_PUBLIC_API_URL=

# Write lightweight HTTP request logs from Next middleware.
# Normally false when nginx proxy logging is enabled, because nginx logs include status codes.
LOG_HTTP_REQUESTS=false

# Write Prisma SQL queries to app logs.
# Enable only temporarily for debugging, because SQL parameters may contain sensitive data.
LOG_PRISMA_QUERIES=false

# Directory inside the web container for captured error screenshots/images.
# In compose it is mounted from ./logs/error-images.
ERROR_IMAGES_DIR=/app/logs/error-images
