# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/

# next.js
/.next/
/out/

# production
/build
/dist

# misc
.DS_Store
Thumbs.db
*.pem
*.tmp
*.temp
/tmp/
/temp/

# debug and runtime logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
*.err.log
*.pid
*.seed

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local runtime logs and captured error images
/logs/

# local databases and dumps
*.sqlite
*.sqlite3
*.db
*.dump
*.bak

# docker/local runtime data
docker-compose.override.yml
compose.override.yaml
compose.override.yml

# vercel
.vercel

# editor/local tooling
.idea/
.history/

# typescript
*.tsbuildinfo
next-env.d.ts
